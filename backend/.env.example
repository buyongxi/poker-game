# App settings
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production-use-long-random-string

# Database
DATABASE_URL=sqlite+aiosqlite:///./poker.db

# JWT
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# CORS (comma-separated for multiple origins)
CORS_ORIGINS=["http://localhost:5173", "http://127.0.0.1:5173"]

# Game settings
ACTION_TIMEOUT=30

# Initial admin account (created on first run if no users exist)
# Leave empty to skip auto-creation, or pass via command line
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_DISPLAY_NAME=
